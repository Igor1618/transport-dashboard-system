    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO driver_reports (id, number, date_from, date_to, driver_id, driver_name, vehicle_id, vehicle_number, fuel_start, fuel_end, mileage, fuel_quantity, fuel_amount, total_expenses, driver_accruals, driver_payments, synced_at)\nVALUES ('{{ $json.id }}', '{{ $json.number }}', '{{ $json.date_from }}', '{{ $json.date_to }}', '{{ $json.driver_id }}', '{{ $json.driver_name }}', '{{ $json.vehicle_id }}', '{{ $json.vehicle_number }}', {{ $json.fuel_start }}, {{ $json.fuel_end }}, {{ $json.mileage }}, {{ $json.fuel_quantity }}, {{ $json.fuel_amount }}, {{ $json.total_expenses }}, {{ $json.driver_accruals }}, {{ $json.driver_payments }}, NOW())\nON CONFLICT (id) DO UPDATE SET\n  number = EXCLUDED.number,\n  date_from = EXCLUDED.date_from,\n  date_to = EXCLUDED.date_to,\n  driver_id = EXCLUDED.driver_id,\n  driver_name = EXCLUDED.driver_name,\n  vehicle_id = EXCLUDED.vehicle_id,\n  vehicle_number = EXCLUDED.vehicle_number,\n  fuel_start = EXCLUDED.fuel_start,\n  fuel_end = EXCLUDED.fuel_end,\n  mileage = EXCLUDED.mileage,\n  fuel_quantity = EXCLUDED.fuel_quantity,\n  fuel_amount = EXCLUDED.fuel_amount,\n  total_expenses = EXCLUDED.total_expenses,\n  driver_accruals = EXCLUDED.driver_accruals,\n  driver_payments = EXCLUDED.driver_payments,\n  synced_at = NOW()",
        "options": {}
      },
      "name": "Upsert: Driver Reports to Supabase",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [850, 650],
      "id": "upsert-driver-reports",
      "notes": "Upsert отчетов водителей",
      "credentials": {
        "postgres": {
          "id": "supabase-postgres",
          "name": "Supabase PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Обработка expense_categories из driver_reports\nconst items = [];\n\nfor (const item of $input.all()) {\n  const reportId = item.json.id;\n  const expenseCategories = item.json.expense_categories || [];\n  \n  for (const category of expenseCategories) {\n    items.push({\n      json: {\n        driver_report_id: reportId,\n        category: category.category,\n        amount: category.amount\n      }\n    });\n  }\n}\n\nreturn items;"
      },
      "name": "Extract: Expense Categories",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 800],
      "id": "extract-expense-categories",
      "notes": "Извлечь массив expense_categories из каждого отчета"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=DELETE FROM expense_categories WHERE driver_report_id IN (SELECT id FROM driver_reports WHERE date_from >= NOW() - INTERVAL '30 days')",
        "options": {}
      },
      "name": "Clear: Old Expense Categories",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [850, 800],
      "id": "clear-expense-categories",
      "notes": "Удалить старые категории расходов за последние 30 дней",
      "credentials": {
        "postgres": {
          "id": "supabase-postgres",
          "name": "Supabase PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": "public",
        "table": "expense_categories",
        "columns": "driver_report_id, category, amount",
        "options": {}
      },
      "name": "Insert: Expense Categories",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1050, 800],
      "id": "insert-expense-categories",
      "notes": "Вставить категории расходов",
      "credentials": {
