    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
      },
      "name": "Merge: All Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [1250, 400],
      "id": "merge-results",
      "notes": "Объединить все результаты синхронизации"
    },
    {
      "parameters": {
        "jsCode": "// Создать отчет о синхронизации\nconst now = new Date().toISOString();\nconst summary = {\n  sync_time: now,\n  vehicles_synced: $('GET: Vehicles from 1C').all().length,\n  drivers_synced: $('GET: Drivers from 1C').all().length,\n  contracts_synced: $('GET: Contracts (Last 30 Days)').all().length,\n  driver_reports_synced: $('GET: Driver Reports (Last 30 Days)').all().length,\n  expense_categories_synced: $('Extract: Expense Categories').all().length,\n  status: 'success'\n};\n\nconsole.log('✅ Sync completed:', summary);\n\nreturn [{ json: summary }];"
      },
      "name": "Create: Sync Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 400],
      "id": "create-sync-report",
      "notes": "Создать отчет о результатах синхронизации"
    }
