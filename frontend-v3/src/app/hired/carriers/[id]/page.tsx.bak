"use client";
import { useState, useEffect } from "react";
import { useParams, useRouter } from "next/navigation";
import { useAuth } from "@/components/AuthProvider";
import { ArrowLeft, Edit2, Save, X, Plus, Trash2, Truck, Phone, Mail, Building2, CreditCard, FileText } from "lucide-react";

function hdr(role: string) {
  return { 'x-user-role': role, 'Cache-Control': 'no-cache' };
}

function isWbHidden(role: string) {
  return role === 'logist';
}

interface Carrier {
  id: string; name: string; inn: string; kpp: string;
  contact_person: string; phone: string; email: string;
  legal_address: string; bank_name: string; bank_account: string;
  bank_bik: string; bank_corr_account: string; contact_position: string;
  default_price: number; status: string; score: number;
  score_breakdown: any; notes: string; created_at: string;
  type: string; ogrn: string; ati_id: string; goslog_reg: string;
  is_active: boolean;
}

interface Vehicle {
  id: number; carrier_id: string; vehicle_plate: string;
  vehicle_model: string; driver_name: string; driver_phone: string;
}

interface Trip {
  id: string; wb_trip_number: string; route: string;
  loading_date: string; vehicle_plate: string; total_price: number;
  our_price: number; status: string;
}

export default function CarrierDetailPage() {
  const params = useParams();
  const router = useRouter();
  const { role } = useAuth();
  const carrierId = params?.id as string;
  const headers = hdr(role || 'director');

  const [carrier, setCarrier] = useState<Carrier | null>(null);
  const [vehicles, setVehicles] = useState<Vehicle[]>([]);
  const [trips, setTrips] = useState<Trip[]>([]);
  const [tripStats, setTripStats] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [pageError, setPageError] = useState('');
  const [editing, setEditing] = useState<string | null>(null);
  const [editVal, setEditVal] = useState('');
  const [showAddVehicle, setShowAddVehicle] = useState(false);
  const [newVehicle, setNewVehicle] = useState({ vehicle_plate: '', vehicle_model: '', driver_name: '', driver_phone: '' });
  const [reqsOpen, setReqsOpen] = useState(false);

  useEffect(() => {
    if (!carrierId) return;
    loadData();
  }, [carrierId]);

  const loadData = async () => {
    try {
      const [cRes, vRes, tRes] = await Promise.all([
        fetch(`/api/hired/carriers/${carrierId}`, { headers }).then(r => r.ok ? r.json() : null),
        fetch(`/api/hired/carriers/${carrierId}/vehicles`, { headers }).then(r => r.ok ? r.json() : []).catch(() => []),
        fetch(`/api/hired/trips?carrier_id=${carrierId}&limit=100`, { headers }).then(r => r.ok ? r.json() : { trips: [], stats: null }).catch(() => ({ trips: [], stats: null })),
      ]);
      if (cRes?.carrier) setCarrier(cRes.carrier);
      else if (cRes && !cRes.carrier) setCarrier(cRes);
      if (Array.isArray(vRes)) setVehicles(vRes);
      else if (vRes?.vehicles) setVehicles(vRes.vehicles);
      if (tRes?.trips) setTrips(tRes.trips);
      if (tRes?.stats) setTripStats(tRes.stats);
    } catch (e: any) {
      setPageError(e.message || 'Ошибка загрузки');
    }
    setLoading(false);
  };

  const saveField = async (field: string, value: string) => {
    if (!carrier) return;
    const body: any = {};
    body[field] = value || null;
    try {
      const r = await fetch(`/api/hired/carriers/${carrierId}`, {
        method: 'PUT', headers: { ...headers, 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...carrier, [field]: value || null })
      });
      if (r.ok) {
        setCarrier({ ...carrier, [field]: value } as Carrier);
      }
    } catch (e) { console.error(e); }
    setEditing(null);
  };

  const saveRequisite = async (field: string, value: string) => {
    if (!carrier) return;
    try {
      const endpoint = `/api/hired/accounting/carriers/${carrierId}/requisites`;
      const r = await fetch(endpoint, {
        method: 'PATCH', headers: { ...headers, 'Content-Type': 'application/json' },
        body: JSON.stringify({ [field]: value || null })
      });
      if (r.ok) {
        setCarrier({ ...carrier, [field]: value } as Carrier);
      } else {
        // Fallback to PUT carrier
        await saveField(field, value);
      }
    } catch (e) {
      await saveField(field, value);
    }
    setEditing(null);
  };

  const addVehicle = async () => {
    if (!newVehicle.vehicle_plate) return;
    try {
      const r = await fetch(`/api/hired/carriers/${carrierId}/vehicles`, {
        method: 'POST', headers: { ...headers, 'Content-Type': 'application/json' },
        body: JSON.stringify(newVehicle)
      });
      if (r.ok) {
        setNewVehicle({ vehicle_plate: '', vehicle_model: '', driver_name: '', driver_phone: '' });
        setShowAddVehicle(false);
        const vRes = await fetch(`/api/hired/carriers/${carrierId}/vehicles`, { headers });
        if (vRes.ok) { const d = await vRes.json(); setVehicles(Array.isArray(d) ? d : d.vehicles || []); }
      }
    } catch (e) { console.error(e); }
  };

  const deleteVehicle = async (vid: number) => {
    if (!confirm('Удалить ТС?')) return;
    await fetch(`/api/hired/carriers/${carrierId}/vehicles/${vid}`, { method: 'DELETE', headers });
    setVehicles(vehicles.filter(v => v.id !== vid));
  };

  if (loading) return <div className="min-h-screen bg-slate-900 flex items-center justify-center text-white">Загрузка...</div>;
  if (pageError) return <div className="min-h-screen bg-slate-900 flex items-center justify-center"><div className="text-center"><div className="text-red-400 text-lg mb-2">❌ {pageError}</div><button onClick={() => router.back()} className="text-blue-400 hover:underline">← Назад</button></div></div>;
  if (!carrier) return <div className="min-h-screen bg-slate-900 flex items-center justify-center text-red-400">Перевозчик не найден</div>;

  const c = carrier;

  const reqFields = [
    { key: 'inn', label: 'ИНН', icon: '🔢' },
    { key: 'kpp', label: 'КПП', icon: '📋' },
    { key: 'legal_address', label: 'Юр. адрес', icon: '📍' },
    { key: 'bank_name', label: 'Банк', icon: '🏦' },
    { key: 'bank_account', label: 'Р/с', icon: '💳' },
    { key: 'bank_bik', label: 'БИК', icon: '🔑' },
    { key: 'bank_corr_account', label: 'К/с', icon: '🔗' },
    { key: 'contact_person', label: 'Контактное лицо', icon: '👤' },
    { key: 'contact_position', label: 'Должность', icon: '💼' },
    { key: 'phone', label: 'Телефон', icon: '📞' },
    { key: 'email', label: 'Email', icon: '✉️' },
  ];

  return (
    <div className="min-h-screen bg-slate-900 text-white p-4 md:p-6 max-w-5xl mx-auto">
      {/* Header */}
      <div className="flex items-center gap-3 mb-6">
        <button onClick={() => router.push('/hired')} className="text-slate-400 hover:text-white">
          <ArrowLeft className="w-5 h-5" />
        </button>
        <div className="flex-1">
          <h1 className="text-xl font-bold">{c.name}</h1>
          <div className="text-sm text-slate-400">ID: {c.id}</div>
        </div>
        {c.score > 0 && (
          <div className={`px-3 py-1 rounded-full text-sm font-bold ${c.score >= 80 ? 'bg-green-600' : c.score >= 50 ? 'bg-yellow-600' : 'bg-red-600'}`}>
            ⭐ {c.score}
          </div>
        )}
      </div>

      {/* Quick info */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div className="bg-slate-800 rounded-lg p-3 border border-slate-700">
          <div className="text-xs text-slate-400">ИНН</div>
          <div className="text-white font-medium">{c.inn || '—'}</div>
        </div>
        <div className="bg-slate-800 rounded-lg p-3 border border-slate-700">
          <div className="text-xs text-slate-400">Телефон</div>
          <div className="text-white font-medium">{c.phone || '—'}</div>
        </div>
        <div className="bg-slate-800 rounded-lg p-3 border border-slate-700">
          <div className="text-xs text-slate-400">Контакт</div>
          <div className="text-white font-medium">{c.contact_person || '—'}</div>
        </div>
        <div className="bg-slate-800 rounded-lg p-3 border border-slate-700">
          <div className="text-xs text-slate-400">Статус</div>
          <div className={`font-medium ${c.is_active !== false ? 'text-green-400' : 'text-red-400'}`}>
            {c.is_active !== false ? '✅ Активен' : '❌ Неактивен'}
          </div>
        </div>
      </div>

      {/* Trip stats */}
      {tripStats && (
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
          <div className="bg-slate-800 rounded-lg p-3 border border-slate-700">
            <div className="text-xs text-slate-400">Рейсов</div>
            <div className="text-white font-bold text-lg">{tripStats.trip_count || trips.length}</div>
          </div>

          <div className="bg-slate-800 rounded-lg p-3 border border-slate-700">
            <div className="text-xs text-slate-400">Штрафы</div>
            <div className="text-red-400 font-bold">{(tripStats.total_penalties || 0).toLocaleString()} ₽</div>
          </div>
        </div>
      )}

      {/* Requisites - collapsible */}
      <div className="bg-slate-800 border border-slate-700 rounded-xl mb-6 overflow-hidden">
        <button onClick={() => setReqsOpen(!reqsOpen)} className="w-full px-4 py-3 flex justify-between items-center hover:bg-slate-750">
          <span className="text-white font-medium">📝 Реквизиты</span>
          <span className="text-slate-400">{reqsOpen ? '▲' : '▼'}</span>
        </button>
        {reqsOpen && (
          <div className="px-4 pb-4 divide-y divide-slate-700/50">
            {reqFields.map(f => (
              <div key={f.key} className="py-2 flex items-center justify-between">
                <span className="text-xs text-slate-400 w-32 shrink-0">{f.icon} {f.label}</span>
                {editing === f.key ? (
                  <div className="flex gap-1 flex-1 ml-2">
                    <input value={editVal} onChange={e => setEditVal(e.target.value)}
                      className="flex-1 bg-slate-700 text-white text-sm px-2 py-1 rounded border border-slate-600" autoFocus
                      onKeyDown={e => { if (e.key === 'Enter') saveRequisite(f.key, editVal); if (e.key === 'Escape') setEditing(null); }} />
                    <button onClick={() => saveRequisite(f.key, editVal)} className="px-2 py-1 bg-green-700 rounded text-xs text-white">✅</button>
                    <button onClick={() => setEditing(null)} className="px-2 py-1 bg-slate-600 rounded text-xs text-white">✕</button>
                  </div>
                ) : (
                  <div className="flex items-center gap-2 flex-1 ml-2 cursor-pointer group" onClick={() => { setEditing(f.key); setEditVal((c as any)[f.key] || ''); }}>
                    <span className="text-white text-sm">{(c as any)[f.key] || '—'}</span>
                    <span className="text-slate-600 group-hover:text-slate-400 text-xs">✏️</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      {/* Vehicles */}
      <div className="bg-slate-800 border border-slate-700 rounded-xl mb-6 overflow-hidden">
        <div className="px-4 py-3 flex justify-between items-center border-b border-slate-700">
          <span className="text-white font-medium">🚛 Транспорт ({vehicles.length})</span>
          <button onClick={() => setShowAddVehicle(!showAddVehicle)} className="text-xs bg-blue-600 hover:bg-blue-700 px-3 py-1 rounded text-white">
            <Plus className="w-3 h-3 inline mr-1" />Добавить
          </button>
        </div>
        {showAddVehicle && (
          <div className="px-4 py-3 border-b border-slate-700 bg-slate-850">
            <div className="grid grid-cols-2 md:grid-cols-4 gap-2 mb-2">
              <input placeholder="Госномер *" value={newVehicle.vehicle_plate} onChange={e => setNewVehicle({ ...newVehicle, vehicle_plate: e.target.value })} className="bg-slate-700 text-white text-sm px-2 py-1.5 rounded border border-slate-600" />
              <input placeholder="Модель" value={newVehicle.vehicle_model} onChange={e => setNewVehicle({ ...newVehicle, vehicle_model: e.target.value })} className="bg-slate-700 text-white text-sm px-2 py-1.5 rounded border border-slate-600" />
              <input placeholder="Водитель" value={newVehicle.driver_name} onChange={e => setNewVehicle({ ...newVehicle, driver_name: e.target.value })} className="bg-slate-700 text-white text-sm px-2 py-1.5 rounded border border-slate-600" />
              <input placeholder="Телефон" value={newVehicle.driver_phone} onChange={e => setNewVehicle({ ...newVehicle, driver_phone: e.target.value })} className="bg-slate-700 text-white text-sm px-2 py-1.5 rounded border border-slate-600" />
            </div>
            <div className="flex gap-2">
              <button onClick={addVehicle} disabled={!newVehicle.vehicle_plate} className="text-xs bg-green-600 disabled:bg-slate-600 px-3 py-1 rounded text-white">Сохранить</button>
              <button onClick={() => setShowAddVehicle(false)} className="text-xs bg-slate-600 px-3 py-1 rounded text-white">Отмена</button>
            </div>
          </div>
        )}
        {vehicles.length > 0 ? (
          <div className="divide-y divide-slate-700/50">
            {vehicles.map(v => (
              <div key={v.id} className="px-4 py-2 flex items-center justify-between">
                <div>
                  <span className="text-white font-medium">{v.vehicle_plate}</span>
                  {v.vehicle_model && <span className="text-slate-400 ml-2 text-sm">{v.vehicle_model}</span>}
                </div>
                <div className="flex items-center gap-3">
                  {v.driver_name && <span className="text-sm text-slate-300">{v.driver_name}</span>}
                  {v.driver_phone && <span className="text-xs text-slate-500">{v.driver_phone}</span>}
                  <button onClick={() => deleteVehicle(v.id)} className="text-slate-500 hover:text-red-400"><Trash2 className="w-3 h-3" /></button>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div className="px-4 py-4 text-sm text-slate-500 text-center">Нет привязанных ТС</div>
        )}
      </div>

      {/* Trips */}
      <div className="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden">
        <div className="px-4 py-3 border-b border-slate-700">
          <span className="text-white font-medium">📦 Рейсы ({trips.length})</span>
        </div>
        {trips.length > 0 ? (
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead>
                <tr className="text-slate-400 text-xs border-b border-slate-700">
                  <th className="text-left px-4 py-2">Рейс</th>
                  <th className="text-left px-4 py-2">Маршрут</th>
                  <th className="text-left px-4 py-2">Дата</th>
                  <th className="text-left px-4 py-2">ТС</th>

                </tr>
              </thead>
              <tbody>
                {trips.map((t, i) => (
                  <tr key={t.id || i} className="border-b border-slate-700/50 hover:bg-slate-750">
                    <td className="px-4 py-2 text-blue-400">{t.wb_trip_number || '—'}</td>
                    <td className="px-4 py-2 text-slate-300 max-w-xs truncate">{t.route || '—'}</td>
                    <td className="px-4 py-2 text-slate-400">{t.loading_date?.slice(0, 10) || '—'}</td>
                    <td className="px-4 py-2 text-slate-300">{t.vehicle_plate || '—'}</td>

                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div className="px-4 py-4 text-sm text-slate-500 text-center">Нет рейсов</div>
        )}
      </div>

      {/* Notes */}
      {c.notes && (
        <div className="bg-slate-800 border border-slate-700 rounded-xl mt-6 p-4">
          <div className="text-xs text-slate-400 mb-1">📝 Заметки</div>
          <div className="text-white text-sm">{c.notes}</div>
        </div>
      )}
    </div>
  );
}
